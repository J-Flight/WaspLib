(*
# LLM Client
Client to interact with LLMs.
*)

{$DEFINE WL_LLMCLIENT_INCLUDED}
{$INCLUDE_ONCE WaspLib/utils.simba}

(*
## TLLMClient
Responsible for connecting to a LLM server.
This expects an Ollama/OpenAI compatible REST API to talk to.
*)
type
  ELLMService = enum(LOCAL, DEEPSEEK, OPENAI, OLLAMA);

  TLLMClient = record
    Service: ELLMService;
    Client: THTTPClient;
    CustomModel, SystemMessage: String;

    Think, Memory: Boolean;
    Lock: TLock;
    ModelIndex, MaxCharacters, MaxMessages, MaxAttempts: Integer;

    Payload: TJSONObject;

    MsgKeys, Servers: array [ELLMService] of String;
    Models: array [ELLMService] of TStringArray;
    IsSetup: Boolean;

    const PATH: String = WLEnv.CacheDir + 'chats' + PATH_SEP;
  end;

procedure TLLMClient.Setup();
begin
  Self.Client := new THTTPClient();
  Self.Client.RequestHeader['Content-Type'] := 'application/json';
  Self.IsSetup := True;

  Self.Servers[ELLMService.LOCAL]    := 'http://127.0.0.1:11434/api/chat/';
  Self.Servers[ELLMService.DEEPSEEK] := 'https://api.deepseek.com/chat/completions/';
  Self.Servers[ELLMService.OPENAI]   := 'https://api.openai.com/v1/chat/completions/';
  Self.Servers[ELLMService.OLLAMA]   := 'https://ollama.com/api/chat/';

  Self.Models[ELLMService.DEEPSEEK] := ['deepseek-v4-flash', 'deepseek-v4-pro'];
  Self.Models[ELLMService.OPENAI]   := ['gpt-5.5', 'gpt-5.4', 'gpt-5.4-mini'];
  Self.Models[ELLMService.OLLAMA]   := ['gemma3'];

  Self.MsgKeys[ELLMService.LOCAL]    := 'messages';
  Self.MsgKeys[ELLMService.DEEPSEEK] := 'messages';
  Self.MsgKeys[ELLMService.OPENAI]   := 'input';
  Self.MsgKeys[ELLMService.OLLAMA]   := 'messages';

  Self.MaxCharacters := 180;
  Self.MaxMessages := 0;
  Self.MaxAttempts := 3;

  if not DirCreate(Self.PATH) then
    raise GetDebugLn('LLMClient', 'Failed to create path: ' + Self.PATH);
end;

property TLLMClient.LocalhostPort(port: Integer);
begin
  if not Self.IsSetup then
    Exit;
  Self.SERVERS[0] := 'http://127.0.0.1:' + ToStr(port) + '/api/chat/';
end;


property TLLMClient.APIKey: String;
begin
  if not Self.IsSetup then
    Exit;
  Result := Self.Client.RequestHeader['Authorization'].After('Bearer ');
end;

property TLLMClient.APIKey(value: String);
begin
  if not Self.IsSetup then
    Exit;
  Self.Client.RequestHeader['Authorization'] := 'Bearer ' + value;
end;


procedure TLLMClient.SetupPayload();
var
  thinking: TJSONObject;
begin
  Self.Payload := new TJSONObject();

  case Self.Service of
    ELLMService.LOCAL:
    begin
      Self.Payload.AddString('model', Self.CustomModel);
      Self.Payload.AddBool('think', Self.Think);
    end;

    ELLMService.OLLAMA:
    begin
      Self.Payload.AddString('model', Self.Models[Self.Service][Self.ModelIndex]);
      Self.Payload.AddBool('think', Self.Think);
    end;

    ELLMService.DEEPSEEK:
    begin
      thinking := new TJSONObject();
      if Self.Think then
        thinking.AddString('type', 'enabled')
      else
        thinking.AddString('type', 'disabled');

      Self.Payload.AddString('model', Self.Models[Self.Service][Self.ModelIndex]);
      Self.Payload.AddObject('thinking', thinking);
    end;

    ELLMService.OPENAI:
    begin
      thinking := new TJSONObject();
      if Self.Think then
        thinking.AddString('effort', 'medium')
      else
        thinking.AddString('effort', 'none');

      Self.Payload.AddString('model', Self.Models[Self.Service][Self.ModelIndex]);
      Self.Payload.AddObject('reasoning', thinking);
    end;
  end;

  Self.Payload.AddBool('stream', False);
end;


function TLLMClient.GetChat(user: String): TJSONArray;
var
  msg: TJSONObject;
  parser: TJSONParser;
  i: Integer;
begin
  Result := new TJSONArray();

  msg := new TJSONObject();
  msg.AddString('role', 'system');
  msg.AddString('content', 'Your messages should never exceed ' + ToStr(Self.MaxCharacters) + ', the more concise they are the better.');
  Result.AddObject('msg', msg);

  msg := new TJSONObject();
  msg.AddString('role', 'system');
  msg.AddString('content', Self.SystemMessage);
  Result.AddObject('msg', msg);

  msg := new TJSONObject();
  msg.AddString('role', 'system');
  msg.AddString('content', 'The user you are talking to is "' + user + '", avoid referring to him directly but keep it in mind if you need to.');
  Result.AddObject('msg', msg);

  if not Self.Memory then
    Exit;
  if not FileExists(Self.PATH + user + '.json') then
    Exit;

  parser := new TJSONParser();
  parser.Load(Self.PATH + user + '.json');

  for i := 0 to parser.Count - 1 do
    if parser.Item[i].Item['role'].AsString <> 'system' then
      Result.AddObject('msg', parser.Item[i].Clone());
end;


function TLLMClient.Chat(user, message: String): String;
var
  payload, msg: TJSONObject;
  msgs: TJSONArray;
  request, response: String;
  parser: TJSONParser;
  i: Integer;
begin
  if not Self.IsSetup then
    Exit;

  payload := Self.Payload.Clone();
  msgs := Self.GetChat(user);

  msg := new TJSONObject();
  msg.AddString('role', 'user');
  msg.AddString('content', message);
  msgs.AddObject('message', msg);

  payload.AddArray(Self.MsgKeys[Self.Service], msgs.Clone());
  request := payload.Format();

  for i := Self.MaxAttempts downto 0 do
  begin
    if i = 0 then
      Exit;

    response := Self.Client.Post(Self.Servers[Self.Service], request);
    if not InRange(Self.Client.ResponseStatus.AsInteger, 200, 299) then
      Continue;

    parser := new TJSONParser();
    parser.Parse(response);

    if not parser.Has('message') then
      Continue;
    if not parser.Item['message'].Has('content') then
      Continue;

    response := parser.Item['message'].Item['content'].AsString;

    if Length(response) <= Self.MaxCharacters then
      Break;
  end;

  Result := response;

  if not Self.Memory then
    Exit;

  msgs.AddObject('message', parser.Item['message'].Clone());
  if not FileWrite(Self.PATH + user + '.json', msgs.Format()) then
    raise GetDebugLn('LLMClient', 'Failed to delete file: ' + Self.PATH + user + '.json');
end;


var
  LLMClient: TLLMClient;
