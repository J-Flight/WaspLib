    'List of currently active antiban walking tasks.'
  );
  lbl.Font.Name := 'Courier New';
  lbl.Align := ELazAlign.Top;
  lbl.BorderSpacing.Top := 10;
  lbl.BorderSpacing.Left := 13;
  lbl.BorderSpacing.Right := 10;

  Self.WalkList := TLazListBox.CreateEx(rPanel);
  Self.WalkList.Font.Name := 'Courier New';
  Self.WalkList.OnSelectionChange := @Self.OnWalkSelected;
  Self.WalkList.OnKeyDown := @Self.OnListKeyDown;
  Self.WalkList.Align := ELazAlign.Client;
  Self.WalkList.BorderSpacing.Left := 10;
  Self.WalkList.BorderSpacing.Right := 10;
  Self.WalkList.BorderSpacing.Bottom := 10;

  Self.WalkAddButton := TLazButton.CreateEx(lPanel, 'Add', 'Add a new walking task.');
  Self.WalkAddButton.OnClick := @Self.OnWalkAdd;
  Self.WalkAddButton.Align := ELazAlign.Bottom;
  Self.WalkAddButton.BorderSpacing.Top := 10;
  Self.WalkAddButton.BorderSpacing.Left := 10;
  Self.WalkAddButton.BorderSpacing.Right := 10;
  Self.WalkAddButton.BorderSpacing.Bottom := 5;

  Self.WalkEditButton := TLazButton.CreateEx(lPanel, 'Update', 'Update the current walking task.');
  Self.WalkEditButton.Enabled := False;
  Self.WalkEditButton.OnClick := @Self.OnWalkEdit;
  Self.WalkEditButton.Align := ELazAlign.Bottom;
  Self.WalkEditButton.BorderSpacing.Top := 5;
  Self.WalkEditButton.BorderSpacing.Left := 10;
  Self.WalkEditButton.BorderSpacing.Right := 10;
  Self.WalkEditButton.BorderSpacing.Bottom := 5;

  Self.WalkDelButton := TLazButton.CreateEx(lPanel, 'Remove', 'Remove the current walking task.');
  Self.WalkDelButton.Enabled := False;
  Self.WalkDelButton.OnClick := @Self.OnWalkRemove;
  Self.WalkDelButton.Align := ELazAlign.Bottom;
  Self.WalkDelButton.BorderSpacing.Top := 5;
  Self.WalkDelButton.BorderSpacing.Left := 10;
  Self.WalkDelButton.BorderSpacing.Right := 10;
  Self.WalkDelButton.BorderSpacing.Bottom := 30;

  Self.WalkPresetButton := TLazButton.CreateEx(lPanel, 'Preset', 'Reset the walking task list with a preset.');
  Self.WalkPresetButton.OnClick := @Self.OnWalkPreset;
  Self.WalkPresetButton.Align := ELazAlign.Bottom;
  Self.WalkPresetButton.BorderSpacing.Around := 10;


  Self.WalkVariationSpinner := TLazSpinEdit.CreateEx(lPanel, '', 'Edit the currently selected walk task interval variation.');
  Self.WalkVariationSpinner.Value := 33;
  Self.WalkVariationSpinner.MinValue := 0;
  Self.WalkVariationSpinner.MaxValue := 100;
  Self.WalkVariationSpinner.Increment := 5;
  Self.WalkVariationSpinner.ValueEmpty := False;
  Self.WalkVariationSpinner.Align := ELazAlign.Top;
  Self.WalkVariationSpinner.BorderSpacing.Left := 10;
  Self.WalkVariationSpinner.BorderSpacing.Right := 10;
  Self.WalkVariationSpinner.BorderSpacing.Bottom := 10;

  lbl := TLazLabel.CreateEx(lPanel, 'Variation (%):', 'Edit the currently selected walk task interval variation.');
  lbl.Align := ELazAlign.Top;
  lbl.BorderSpacing.Top := 10;
  lbl.BorderSpacing.Left := 10;
  lbl.BorderSpacing.Right := 10;

  Self.WalkIntervalSpinner := TLazFloatSpinEdit.CreateEx(lPanel, '', 'Edit the currently selected walk task interval.');
  Self.WalkIntervalSpinner.Text := '5';
  Self.WalkIntervalSpinner.Align := ELazAlign.Top;
  Self.WalkIntervalSpinner.BorderSpacing.Left := 10;
  Self.WalkIntervalSpinner.BorderSpacing.Right := 10;
  Self.WalkIntervalSpinner.BorderSpacing.Bottom := 10;

  lbl := TLazLabel.CreateEx(lPanel, 'Interval (mins):', 'Edit the currently selected walk task interval.');
  lbl.Align := ELazAlign.Top;
  lbl.BorderSpacing.Top := 10;
  lbl.BorderSpacing.Left := 10;
  lbl.BorderSpacing.Right := 10;

  Self.WalkCombobox := TLazComboBox.CreateEx(lPanel, '', 'Edit the currently selected walking task.');

  for i := 0 to High(ANTIBAN_WALKING_TASKS) do
    Self.WalkCombobox.Items.Add(ANTIBAN_WALKING_TASKS[i].Name);

  Self.WalkCombobox.ItemIndex := 0;
  Self.WalkCombobox.Align := ELazAlign.Top;
  Self.WalkCombobox.BorderSpacing.Left := 10;
  Self.WalkCombobox.BorderSpacing.Right := 10;
  Self.WalkCombobox.BorderSpacing.Bottom := 10;

  lbl := TLazLabel.CreateEx(lPanel, 'Walking Task:', 'Edit the currently selected walking task.');
  lbl.Align := ELazAlign.Top;
  lbl.BorderSpacing.Top := 10;
  lbl.BorderSpacing.Left := 10;
  lbl.BorderSpacing.Right := 10;
end;


var
(*
## AntibanForm variable
Global {ref}`TAntibanFormHelper` variable.
*)
  AntibanForm: TAntibanFormHelper;

(*
## ScriptForm.CreateAntibanTab
```pascal
function TScriptForm.CreateAntibanTab(): TLazTabSheet;
```
Sets up a `TLazTabSheet` on your `TScriptForm` to configure your {ref}`Antiban`.

Example:
```pascal
{$I WaspLib/osrs.simba}
var
  form: TScriptForm;
begin
  form.Setup();
  form.CreateAntibanTab();
  form.Run();
end.
```
```{figure} ../../images/antibanform.gif
```
*)
function TScriptForm.CreateAntibanTab(): TLazTabSheet;
var
  tab: TLazTabSheet;
  lbl: TLazLabel;
begin
  Result := Self.CreateTab('Antiban');

  AntibanForm.PageControl := TLazPageControl.CreateEx(Result);
  AntibanForm.PageControl.Align := ELazAlign.Client;
  AntibanForm.PageControl.BorderSpacing.Around := 10;

  tab := AntibanForm.PageControl.AddTab();
  tab.Caption := 'Tasks';
  AntibanForm.SetupTaskPanel(tab);

  tab := AntibanForm.PageControl.AddTab();
  tab.Caption := 'Breaks';
  AntibanForm.SetupBreaksPanel(tab);

  tab := AntibanForm.PageControl.AddTab();
  tab.Caption := 'Sleep';
  AntibanForm.SetupSleepsPanel(tab);

  tab := AntibanForm.PageControl.AddTab();
  tab.Caption := 'Walking';
  AntibanForm.SetupWalkPanel(tab);

  lbl := TLazLabel.CreateEx(
           Result,
           'Everything in antiban will have randomization added/subtracted to the values you pick, roughly 25% + "Variation".' +
           LINE_SEP +
           'Each profile has it''s own antiban settings.'
         );
  lbl.Align := ELazAlign.Bottom;
  lbl.Alignment := ELazAlignment.Center;
  lbl.BorderSpacing.Around := 20;

  AntibanForm.Setup();
  ProfileForm.ProfileUpdateTasks += @AntibanForm.Setup;
end;
